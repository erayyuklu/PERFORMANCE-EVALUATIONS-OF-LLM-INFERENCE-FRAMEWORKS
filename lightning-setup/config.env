# =============================================================================
# Lightning.ai vLLM Configuration
# =============================================================================

# --- Model ---
MODEL="deepseek-ai/DeepSeek-R1-Distill-Qwen-7B"

# --- vLLM Serve Parameters ---
PORT=8000
MAX_MODEL_LEN=4096
GPU_MEMORY_UTILIZATION=0.9
DTYPE="half"
TENSOR_PARALLEL_SIZE=1

# --- Hugging Face ---
# Set your HF token here or export it before running:
#   export HF_TOKEN="hf_xxxxx"
# HF_TOKEN=""
