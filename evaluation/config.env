# --- Model ---
MODEL_NAME="deepseek-ai/DeepSeek-R1-Distill-Qwen-7B"

# --- Hugging Face (imported from vllm/secrets.env) ---
# HF_TOKEN=""

# --- Kubernetes (used to discover vLLM endpoint) ---
K8S_NAMESPACE="vllm"

# --- Evaluation ---
TASKS="gsm8k,mmlu,hellaswag,arc_challenge,truthfulqa_mc2"
NUM_FEWSHOT=5
BATCH_SIZE="auto"
NUM_CONCURRENT=32
OUTPUT_DIR="./results"
ENABLE_THINKING=true
LIMIT=100 # remove when evaluating full dataset; set to a small number for testing
