# --- Model ---
MODEL_NAME="Qwen/Qwen2.5-7B-Instruct"

# --- Hugging Face (imported from vllm/secrets.env) ---
# HF_TOKEN=""

# --- Kubernetes (used to discover vLLM endpoint) ---
K8S_NAMESPACE="vllm"

# --- Evaluation ---
TASKS="mmlu"
NUM_FEWSHOT=5
BATCH_SIZE="auto"
NUM_CONCURRENT=32
TIMEOUT=600
OUTPUT_DIR="./results"
LIMIT=5