# --- Model ---
MODEL_NAME="Qwen/Qwen3-8B"

# --- Output Directory Formatting ---
MODEL_FAMILY="qwen-3"
QUANTIZATION="noquantization"
REASONING="reasoning"

# --- Kubernetes (used to discover vLLM endpoint) ---
K8S_NAMESPACE="vllm"

# --- Evaluation ---
TASKS="gsm8k,arc_challenge,mmlu"
NUM_FEWSHOT=5
BATCH_SIZE="auto"
NUM_CONCURRENT=24
TIMEOUT=600
OUTPUT_DIR="./results"
ENABLE_THINKING=true
LIMIT=1000