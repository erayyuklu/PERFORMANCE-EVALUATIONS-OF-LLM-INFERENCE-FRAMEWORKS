VLLM_TARGET_HOST=http://vllm-service.vllm.svc.cluster.local
VLLM_MODEL_NAME=Qwen/Qwen3-8B
VLLM_MAX_TOKENS=-1
VLLM_TEMPERATURE=0.7
VLLM_REQUEST_TIMEOUT=180
VLLM_ENABLE_THINKING=true
DATASET_TYPE=sharegpt
SHAREGPT_PATH=/locust/prompts/sharegpt.json
SHAREGPT_MIN_TURNS=1
CUSTOM_DATASET_PATH=/locust/prompts/dataset.json
VLLM_PROMPT_LEN=all
VLLM_USER_PROFILE=all
LOCUST_PROMETHEUS_PORT=9646
LOCUST_STOP_TIMEOUT=180
LOCUST_ARTIFACTS_DIR=/locust-artifacts
AGENT_TARGET_HOST=http://agent-service.agent.svc.cluster.local
AGENT_REQUEST_TIMEOUT=120
