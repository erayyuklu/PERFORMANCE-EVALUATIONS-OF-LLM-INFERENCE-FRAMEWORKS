{
  "title": "Locust Load Test",
  "uid": "locust-load-test",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "tags": ["locust", "load-test", "vllm"],
  "panels": [

    {
      "id": 1,
      "title": "Active Users",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "none", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "locust_users", "legendFormat": "Users" }
      ]
    },

    {
      "id": 2,
      "title": "Failure Rate",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "locust_fail_ratio", "legendFormat": "Failure Ratio" }
      ]
    },

    {
      "id": 3,
      "title": "Requests Per Second (RPS)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(locust_requests_total[1m])) by (result)",
          "legendFormat": "{{result}}"
        }
      ]
    },

    {
      "id": 4,
      "title": "vLLM - Time to First Token (TTFT) p50 / p95 / p99 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(vllm:time_to_first_token_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "TTFT p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(vllm:time_to_first_token_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "TTFT p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(vllm:time_to_first_token_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "TTFT p99"
        }
      ]
    },

    {
      "id": 5,
      "title": "vLLM - Inter-Token Latency p50 / p95 / p99 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(vllm:inter_token_latency_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "ITL p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(vllm:inter_token_latency_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "ITL p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(vllm:inter_token_latency_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "ITL p99"
        }
      ]
    },

    {
      "id": 6,
      "title": "vLLM - E2E Request Latency p50 / p95 / p99 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(vllm:e2e_request_latency_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "E2E p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(vllm:e2e_request_latency_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "E2E p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(vllm:e2e_request_latency_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "E2E p99"
        }
      ]
    },

    {
      "id": 7,
      "title": "vLLM - Time Per Output Token (TPOT) p50 / p95 / p99 (ms/token)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(vllm:request_time_per_output_token_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "TPOT p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(vllm:request_time_per_output_token_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "TPOT p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(vllm:request_time_per_output_token_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "TPOT p99"
        }
      ]
    },

    {
      "id": 8,
      "title": "vLLM - Prompt Tokens Throughput (tokens/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(vllm:prompt_tokens_total[1m]))",
          "legendFormat": "Prompt tokens/s"
        }
      ]
    },

    {
      "id": 9,
      "title": "vLLM - Generation Tokens Throughput (tokens/s)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 24, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(vllm:generation_tokens_total[1m]))",
          "legendFormat": "Generation tokens/s"
        }
      ]
    },

    {
      "id": 10,
      "title": "vLLM - Request Success Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 24, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(vllm:request_success_total[1m])) by (finished_reason)",
          "legendFormat": "{{finished_reason}}"
        }
      ]
    },

    {
      "id": 11,
      "title": "vLLM - Running & Waiting Requests",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 32, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "none", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(vllm:num_requests_running)",
          "legendFormat": "Running"
        },
        {
          "expr": "sum(vllm:num_requests_waiting)",
          "legendFormat": "Waiting (queue)"
        }
      ]
    },

    {
      "id": 12,
      "title": "vLLM - KV-Cache Utilization (%)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 32, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "vllm:kv_cache_usage_perc",
          "legendFormat": "KV-Cache %"
        }
      ]
    },

    {
      "id": 13,
      "title": "vLLM - Preemptions (events/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 40, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(vllm:num_preemptions_total[1m]))",
          "legendFormat": "Preemptions/s"
        }
      ]
    },

    {
      "id": 14,
      "title": "vLLM - Prefix Cache Hits & Queries",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 40, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(vllm:prefix_cache_hits_total[1m]))",
          "legendFormat": "Cache Hits/s"
        },
        {
          "expr": "sum(rate(vllm:prefix_cache_queries_total[1m]))",
          "legendFormat": "Cache Queries/s"
        }
      ]
    },

    {
      "id": 15,
      "title": "GPU Utilization - DCGM_FI_DEV_GPU_UTIL (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 48, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "avg(DCGM_FI_DEV_GPU_UTIL) by (gpu, modelName)",
          "legendFormat": "GPU {{gpu}} ({{modelName}})"
        }
      ]
    },

    {
      "id": 16,
      "title": "GPU Framebuffer Memory Used - DCGM_FI_DEV_FB_USED (MiB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 48, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "decmbytes", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "avg(DCGM_FI_DEV_FB_USED) by (gpu, modelName)",
          "legendFormat": "GPU {{gpu}} ({{modelName}}) FB Used MiB"
        }
      ]
    },

    {
      "id": 17,
      "title": "Container CPU Usage (cores)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 56, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{container!=\"\", container!=\"POD\"}[1m])) by (container, pod)",
          "legendFormat": "{{container}} / {{pod}}"
        }
      ]
    },

    {
      "id": 18,
      "title": "Container Memory Working Set (bytes)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 56, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{container!=\"\", container!=\"POD\"}) by (container, pod)",
          "legendFormat": "{{container}} / {{pod}}"
        }
      ]
    },

    {
      "id": 19,
      "title": "Container Network I/O (bytes/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 64, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(container_network_receive_bytes_total{container!=\"\"}[1m])) by (pod)",
          "legendFormat": "RX {{pod}}"
        },
        {
          "expr": "sum(rate(container_network_transmit_bytes_total{container!=\"\"}[1m])) by (pod)",
          "legendFormat": "TX {{pod}}"
        }
      ]
    }

  ],
  "templating": {
    "list": []
  }
}
